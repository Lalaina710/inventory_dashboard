<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Catégorie du module -->
    <record id="module_category_inventory_dashboard" model="ir.module.category">
        <field name="name">Dashboard Inventaire</field>
        <field name="sequence">200</field>
    </record>

    <!-- Groupe Utilisateur -->
    <record id="group_inventory_dashboard_user" model="res.groups">
        <field name="name">Utilisateur Dashboard Inventaire</field>
        <field name="category_id" ref="module_category_inventory_dashboard"/>
    </record>

    <!-- Groupe Responsable (implique Utilisateur) -->
    <record id="group_inventory_dashboard_manager" model="res.groups">
        <field name="name">Responsable Dashboard Inventaire</field>
        <field name="category_id" ref="module_category_inventory_dashboard"/>
        <field name="implied_ids" eval="[(4, ref('group_inventory_dashboard_user'))]"/>
    </record>

    <!-- stock.group_stock_manager implique group_inventory_dashboard_manager -->
    <record id="stock.group_stock_manager" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_inventory_dashboard_manager'))]"/>
    </record>
</odoo>
